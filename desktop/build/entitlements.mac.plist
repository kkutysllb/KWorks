<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		Electron macOS entitlements for KWorks.

		These entitlements are required because the app bundles:
		  - Electron (Chromium + Node.js V8 runtime)
		  - node-pty native module (spawns child processes / PTY)
		  - An embedded Node runtime (qiongqi) launched as a child process

		See https://www.electronjs.org/docs/latest/tutorial/mac-code-signing
	-->
	<!-- V8 JIT compiler: required for JavaScript execution performance. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<!-- Some native modules (node-pty) require unsigned executable memory. -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<!-- Allow DYLD_* env vars so the child Node process inherits runtime paths. -->
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
	<!--
		Disable library validation: the app loads the bundled qiongqi Node
		executable and node-pty which are not signed by the same Team ID.
		Without this, hardened-runtime blocks them at launch.
	-->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<!-- Allow debugging/inspecting; electron-updater & devtools need this. -->
	<key>com.apple.security.cs.debugger</key>
	<true/>
</dict>
</plist>
