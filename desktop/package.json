{
  "name": "kworks-desktop",
  "version": "0.3.12",
  "private": true,
  "description": "KWorks desktop — fully self-contained Electron shell wrapping the KWorks frontend and Node QiongQi runtime.",
  "homepage": "https://github.com/kkutysllb/kk_KWorks",
  "author": "KWorks Team <13609247807@139.com>",
  "maintainer": "KWorks Team <13609247807@139.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.preload.json && node scripts/rename-preload.mjs",
    "dev": "node scripts/dev.mjs",
    "start": "electron .",
    "build:icons": "bash scripts/generate-icons.sh",
    "build:frontend": "pnpm --dir ../frontend run build:desktop",
    "prepare:package-resources": "node scripts/prepare-package-resources.mjs",
    "verify:package-resources": "node scripts/verify-package-resources.mjs",
    "verify:built-package-resources": "node scripts/verify-built-package-resources.mjs",
    "fix:node-pty-permissions": "node scripts/fix-node-pty-permissions.mjs",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "build:app": "pnpm run build && pnpm run build:frontend && pnpm run prepare:package-resources && pnpm run verify:package-resources && electron-builder",
    "build:app:full": "pnpm run build:app",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.preload.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@electron/notarize": "^2.5.0",
    "@types/node": "^20.14.10",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.2"
  }
}
